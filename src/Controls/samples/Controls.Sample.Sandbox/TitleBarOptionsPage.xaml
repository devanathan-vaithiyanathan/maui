<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="Maui.Controls.Sample.TitleBarOptionsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:vm="clr-namespace:Maui.Controls.Sample"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="TitleBar Options">
    <ContentPage.BindingContext>
        <vm:TitleBarViewModel/>
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20"
                         Spacing="16">
        <HorizontalStackLayout
            Spacing="10">
            <CheckBox x:Name="FlowDirectionRTLCheckBox"
                      AutomationId="FlowDirectionRTLCheckBox"
                      IsChecked="False"
                      CheckedChanged="OnFlowDirectionCheckBoxChanged"/>
            <Label Text="RTL"
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
    
</ContentPage>
